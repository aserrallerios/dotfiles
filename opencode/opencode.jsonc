{
  "$schema": "https://opencode.ai/config.json",
  // Use GitHub Copilot as default provider (already authenticated via gh CLI)
  "model": "copilot/claude-sonnet-4",
  "small_model": "copilot/gpt-4.1-mini",
  "shell": {
    "path": "/bin/zsh",
    "args": ["-l"]
  },
  "autoupdate": true,
  "share": "manual",
  "compaction": {
    "auto": true,
    "prune": true
  },
  "permission": {
    "edit": "ask",
    "bash": "ask"
  }
}
